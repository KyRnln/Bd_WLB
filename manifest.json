{
  "manifest_version": 3,
  "name": "商务WLB插件",
  "version": "1.5",
  "description": "工作是为了更好的生活",
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://*.tiktok.com/*",
    "https://ads.tiktok.com/*",
    "https://seller.tiktokshopglobalselling.com/*",
    "https://affiliate.tiktokshopglobalselling.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.tiktokcdn-us.com/*",
    "https://*.tiktokv.com/*",
    "https://dav.jianguoyun.com/*",
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://*.tiktok.com https://*.tiktokcdn.com https://*.tiktokcdn-us.com https://*.tiktokv.com https://dav.jianguoyun.com; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tiktok.com/*",
        "https://ads.tiktok.com/*",
        "https://seller.tiktokshopglobalselling.com/*",
        "https://affiliate.tiktokshopglobalselling.com/*",
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "Creator/creator_highlight.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "username_avatarcid/username_avatarcid_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "order/order_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/connection/creator/detail*"
      ],
      "js": [
        "cid_to_name/cid_to_name_content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "商务WLB插件",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page_bridge.js"
      ],
      "matches": [
        "https://*.tiktok.com/*",
        "https://ads.tiktok.com/*",
        "https://seller.tiktokshopglobalselling.com/*",
        "https://affiliate.tiktokshopglobalselling.com/*",
        "*://*/*"
      ]
    }
  ]
}