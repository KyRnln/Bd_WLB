{
  "manifest_version": 3,
  "name": "商务WLB插件",
  "version": "1.6.1",
  "description": "工作是为了更好的生活",

  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://*.tiktok.com/*",
    "https://ads.tiktok.com/*",
    "https://seller.tiktokshopglobalselling.com/*",
    "https://affiliate.tiktokshopglobalselling.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.tiktokcdn-us.com/*",
    "https://*.tiktokv.com/*",
    "https://dav.jianguiyun.com/*",
    "*://*/*"
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://*.tiktok.com https://*.tiktokcdn.com https://*.tiktokcdn-us.com https://*.tiktokv.com https://dav.jianguiyun.com https://*.aliyuncs.com https://api.openai.com https://api.deepseek.com https://* http://localhost:* http://120.24.170.11:* https://kyrnln.cloud; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.tiktok.com/*",
        "https://ads.tiktok.com/*",
        "https://seller.tiktokshopglobalselling.com/*",
        "https://affiliate.tiktokshopglobalselling.com/*",
        "*://*/*"
      ],
      "js": [
        "phrase/phrase_content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "creator/creator_highlight.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "username_avatarcid/username_avatarcid_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/*"
      ],
      "js": [
        "order/order_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/connection/creator/detail*"
      ],
      "js": [
        "cid_to_name/cid_to_name_content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://affiliate.tiktokshopglobalselling.com/seller/im*"
      ],
      "js": [
        "translate/translate_content.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "商务WLB插件",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "commands": {
    "toggle-phrase-selector": {
      "suggested_key": {
        "default": "Alt+Y",
        "mac": "Command+Y"
      },
      "description": "打开快捷短语"
    },
    "toggle-translate": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Command+T"
      },
      "description": "打开快捷翻译"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "page_bridge.js",
        "translate/translate.html"
      ],
      "matches": [
        "https://*.tiktok.com/*",
        "https://ads.tiktok.com/*",
        "https://seller.tiktokshopglobalselling.com/*",
        "https://affiliate.tiktokshopglobalselling.com/*",
        "*://*/*"
      ]
    }
  ]
}
